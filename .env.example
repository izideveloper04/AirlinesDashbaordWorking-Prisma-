# Copy this file to .env and fill in your values

# SQLite database path (relative to prisma/)
DATABASE_URL="file:./database/database.db"

# NextAuth — generate a strong random secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"

# The URL your site is accessed from (localhost for local dev, your domain in production)
# Use your LAN IP when testing from other devices (e.g. http://192.168.1.60:3000)
NEXTAUTH_URL="http://localhost:3000"
